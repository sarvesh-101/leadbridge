# ═══════════════════════════════════════════════════════════════════
# LeadBridge (LeadFlow AI OS) — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# This file documents ALL environment variables across all services.
# Required variables are marked with 🔴, optional with ⚪.
# ═══════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════
# 📦 SHARED / CORE
# ═══════════════════════════════════════════════════════════════════

# 🔴 Application environment
# Values: development | production | test
NODE_ENV=development
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# 🔴 JWT Signing Secrets (generate with: openssl rand -hex 32)
# These MUST be at least 32 characters in production!
JWT_SECRET=change-this-to-a-secure-random-key-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars

# JWT Expiry (optional; defaults below)
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 🔴 Encryption Key (used for encrypting sensitive data like API keys)
# Must be at least 16 characters
ENCRYPTION_KEY=change-this-encryption-key-min-16-chars


# ═══════════════════════════════════════════════════════════════════
# 🗄️ DATABASE — PostgreSQL (required for both servers)
# ═══════════════════════════════════════════════════════════════════

# 🔴 FastAPI backend uses this URL
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadflow_ai

# 🔴 FastAPI sync URL (for Alembic migrations)
# Format: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/leadflow_ai

# 🔴 Fastify/Prisma server uses this URL
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL_PRISMA=postgresql://postgres:postgres@localhost:5432/leadflow_ai

# ⚪ Direct connection URL (for migrations, optional if same as DATABASE_URL)
DIRECT_URL=

# Pool settings (optional)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40


# ═══════════════════════════════════════════════════════════════════
# 🔴 REDIS — Queue & Cache
# ═══════════════════════════════════════════════════════════════════

# Main Redis (used by both servers)
REDIS_URL=redis://:redispass@localhost:6379/0

# Celery broker & result backend (Python backend)
CELERY_BROKER_URL=redis://:redispass@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redispass@localhost:6379/2

# Redis password (if set in docker-compose)
REDIS_PASSWORD=redispass


# ═══════════════════════════════════════════════════════════════════
# 🚀 SERVER CONFIG
# ═══════════════════════════════════════════════════════════════════

# Fastify server port
PORT=3000

# FastAPI backend port
API_PORT=8000

# Frontend URL (for CORS and links)
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:3001

# App name / version
APP_NAME=LeadBridge
APP_VERSION=1.0.0
APP_DESCRIPTION="AI-Powered Lead Recovery & Conversion Management Platform"


# ═══════════════════════════════════════════════════════════════════
# 📞 EXOTEL — Telephony Provider
# ═══════════════════════════════════════════════════════════════════
# Sign up: https://exotel.com
# API docs: https://developer.exotel.com/api/

# ⚪ Get these from your Exotel dashboard
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=


# ═══════════════════════════════════════════════════════════════════
# 🤖 PIPECAT — AI Voice Agent (Microservice)
# ═══════════════════════════════════════════════════════════════════

# URL of the Pipecat Python microservice
PIPECAT_SERVICE_URL=http://localhost:8001
# Secret for authenticating with Pipecat
PIPECAT_SECRET=change-me


# ═══════════════════════════════════════════════════════════════════
# 🧠 AI SERVICES
# ═══════════════════════════════════════════════════════════════════

# LLM Provider — OpenAI-compatible API (OpenRouter, DeepSeek, etc.)
# Used for post-call transcript extraction, WhatsApp chatbot, and script generation.
# 🔴 Required for AI call processing
#
# Default: Qwen3 Next 80B A3B Instruct via OpenRouter (free, fast, multilingual)
# Sign up: https://openrouter.ai/keys
# Alternative models you have API keys for:
#   - qwen/qwen3-next-80b-a3b-instruct:free  ← RECOMMENDED (MoE, 3B active, 262K ctx)
#   - meta-llama/llama-3.3-70b-instruct:free   ← Best Hindi, slower
#   - meta-llama/llama-3.2-3b-instruct:free     ← Fastest, smaller
#   - nousresearch/hermes-3-llama-3.1-405b:free  ← Most capable, very slow
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Deepgram (speech-to-text)
# Sign up: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Cartesia (text-to-speech / voice)
# Sign up: https://cartesia.ai/
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# OpenAI (fallback LLM)
OPENAI_API_KEY=


# ═══════════════════════════════════════════════════════════════════
# 💬 WHATSAPP CLOUD API
# ═══════════════════════════════════════════════════════════════════
# Sign up: https://developers.facebook.com/docs/whatsapp/cloud-api

WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=


# ═══════════════════════════════════════════════════════════════════
# 💳 RAZORPAY — Payment Processing
# ═══════════════════════════════════════════════════════════════════
# Sign up: https://razorpay.com

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Plan IDs (create plans in Razorpay dashboard)
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_PRO=


# ═══════════════════════════════════════════════════════════════════
# ☁️ SUPABASE — File Storage (Call Recordings)
# ═══════════════════════════════════════════════════════════════════
# Sign up: https://supabase.com

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_RECORDINGS_BUCKET=call-recordings


# ═══════════════════════════════════════════════════════════════════
# 📧 RESEND — Email Delivery
# ═══════════════════════════════════════════════════════════════════
# Sign up: https://resend.com

RESEND_API_KEY=
FROM_EMAIL=noreply@leadbridge.com
RESEND_FROM_NAME=LeadBridge
RESEND_FROM_EMAIL=noreply@leadbridge.com


# ═══════════════════════════════════════════════════════════════════
# ☁️ AWS S3 — File Storage (Alternative to Supabase)
# ═══════════════════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=leadflow-ai-storage
AWS_S3_CALLS_FOLDER=call-recordings
AWS_S3_DOCUMENTS_FOLDER=documents


# ═══════════════════════════════════════════════════════════════════
# 📊 MONITORING & ERROR TRACKING
# ═══════════════════════════════════════════════════════════════════

# Sentry (error tracking)
# Sign up: https://sentry.io
SENTRY_DSN=

# Prometheus (metrics)
ENABLE_PROMETHEUS=true


# ═══════════════════════════════════════════════════════════════════
# ⏰ CRON / SCHEDULED TASKS
# ═══════════════════════════════════════════════════════════════════

# Secret for authenticating cron job triggers
CRON_SECRET=change-me-cron-secret


# ═══════════════════════════════════════════════════════════════════
# 🏠 TENANT DEFAULTS
# ═══════════════════════════════════════════════════════════════════

MAX_TENANTS=10000
DEFAULT_TENANT_PLAN=starter


# ═══════════════════════════════════════════════════════════════════
# 🔧 ADVANCED SETTINGS
# ═══════════════════════════════════════════════════════════════════

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# File upload limits (in bytes — default 50MB)
MAX_UPLOAD_SIZE=52428800
ALLOWED_FILE_TYPES=csv,xlsx,pdf,mp3,wav,ogg,txt

# Webhook retries
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT=10

# Celery (async task workers)
CELERY_TASK_ALWAYS_EAGER=false


# ═══════════════════════════════════════════════════════════════════
# 📝 NOTES
# ═══════════════════════════════════════════════════════════════════
#
# 🔴 Python FastAPI backend (backend/) has been DEPRECATED.
#    The TypeScript Fastify server (server/) is the canonical backend.
#    Do NOT run the Python server in production.
#    See backend/DEPRECATED.md for details.
#
# ═══════════════════════════════════════════════════════════════════
# 📝 QUICK SETUP CHECKLIST
# ═══════════════════════════════════════════════════════════════════
#
# Minimum required to run in development:
#   1. Set JWT_SECRET to a random 64-char hex string
#   2. Set JWT_REFRESH_SECRET to a random 64-char hex string
#   3. Set ENCRYPTION_KEY to a random string
#   4. Set DATABASE_URL_PRISMA to your local Postgres
#   5. Set REDIS_URL to your local Redis instance
#   6. Set OMNIDIM_API_KEY (get from Omnidimension dashboard)
#
# Then run:
#   docker compose -f docker/docker-compose.yml up -d postgres redis
#   cd server   && npm install && npm run prisma:push && npm run dev
#   cd frontend && npm install && npm run dev
#
# First-time setup:
#   cd server && npx prisma db seed   # Creates admin + demo data
# ═══════════════════════════════════════════════════════════════════
