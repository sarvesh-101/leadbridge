generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_PRISMA")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum PhoneSetupStatus {
  PENDING
  NUMBER_PURCHASED
  NUMBER_CONNECTED
  LIVE
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

enum PlanStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum LeadStatus {
  PENDING
  CALLING
  CALL_FAILED
  NO_ANSWER
  FAQ_ONLY
  BOOKED
  REMINDED
  VISITED
  NO_SHOW
  FOLLOWUP_D1
  FOLLOWUP_D2
  FOLLOWUP_D3
  REBOOKED
  COLD
  CONVERTED
}

enum CallType {
  QUALIFICATION
  BOOKING_REMINDER
  FOLLOWUP_D1
  FOLLOWUP_D3
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  COMPLETED
  NO_ANSWER
  FAILED
  BUSY
}

enum BookingStatus {
  CONFIRMED
  REMINDED
  VISITED
  NO_SHOW
  RESCHEDULED
  CANCELLED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  resetToken        String?  @unique
  resetTokenExpiresAt DateTime?
  createdAt    DateTime @default(now())
  clients      Client[]
}

model Client {
  id           String    @id @default(cuid())
  adminId      String?
  admin        Admin?    @relation(fields: [adminId], references: [id])

  // Business
  businessName String
  ownerName    String
  email        String    @unique
  phone        String
  city         String
  zone         String?
  territory    Territory?

  // Auth
  passwordHash String
  resetToken        String?  @unique
  resetTokenExpiresAt DateTime?

  // Exotel (legacy — replaced by Omnidimension)
  exotelSid    String?
  exotelNumber String?

  // Omnidimension AI Voice Agent
  omnidimensionAgentId Int?     @unique
  omniAgentId         String?  @unique  // OmniDimension agent UUID (string format)
  omniPhoneNumberId   Int?             // OmniDimension phone number ID
  omniPhoneNumber     String?          // E.164 phone number
  phoneSetupStatus    PhoneSetupStatus @default(PENDING)
  callScript          Json?
  knowledgeBase       String?          // Broker's property knowledge for the AI agent
  agentVoiceId        String?          // ElevenLabs voice ID

  // Language
  language     String    @default("hinglish")

  // WhatsApp
  ownerWhatsapp String

  // Plan
  plan          Plan         @default(GROWTH)
  planStatus    PlanStatus   @default(TRIAL)
  trialEndsAt   DateTime?
  razorpaySubId String?

  // Usage
  callsThisMonth  Int @default(0)
  callsLimit      Int @default(300)

  // Lead sources config
  leadSources     Json @default("[]")

  // Onboarding tracking
  onboardingComplete Boolean @default(false)
  onboardingStep     Int     @default(0) // 0=not started, 1-6=steps, 7=done

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads              Lead[]
  calls              Call[]
  bookings           Booking[]
  webhookSources     WebhookSource[]
  integrations       Integration[]
  ownerNotifications OwnerNotification[]
  campaigns          Campaign[]
  subscriptions      Subscription[]
  invoices           Invoice[]
  payments           Payment[]
  auditLogs          AuditLog[]
  waitlistEntries    WaitlistEntry[]
}

model Territory {
  id       String  @id @default(cuid())
  city     String
  zone     String?
  tier     Int
  clientId String? @unique
  client   Client? @relation(fields: [clientId], references: [id])
  locked   Boolean @default(false)

  // Waitlist for when territory is taken
  waitlistEntries WaitlistEntry[]

  @@unique([city, zone])
}

model WaitlistEntry {
  id         String   @id @default(cuid())
  territoryId String
  territory  Territory @relation(fields: [territoryId], references: [id])

  // Contact info from the person wanting this territory
  name       String
  email      String
  phone      String
  businessName String
  city       String
  zone       String?

  // Status
  notified   Boolean  @default(false)
  notifiedAt DateTime?
  expiresAt  DateTime?

  // If they claimed it later, link to client
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  claimedAt         DateTime?

  createdAt DateTime @default(now())

  @@index([territoryId])
  @@index([email])
}

model Lead {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // Identity
  name     String
  phone    String
  email    String?
  source   String

  // Raw inbound payload (stored for debugging)
  rawPayload Json

  // Qualification (filled after AI call)
  budget        String?
  location      String?
  timeline      String?
  propertyType  String?
  bedrooms      String?
  callLanguage  String?
  sentiment     String?

  // Lifecycle
  score         Int        @default(0)
  status        LeadStatus @default(PENDING)
  callAttempts  Int        @default(0)
  maxAttempts   Int        @default(3)
  nextRetryAt   DateTime?

  // Booking
  bookingId     String?  @unique
  booking       Booking? @relation(fields: [bookingId], references: [id])

  // Follow-up tracking
  followupD1At  DateTime?
  followupD2At  DateTime?
  followupD3At  DateTime?

  // Timestamps
  receivedAt    DateTime @default(now())
  firstCalledAt DateTime?
  bookedAt      DateTime?
  visitedAt     DateTime?
  coldAt        DateTime?
  convertedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calls               Call[]
  customerNotifications CustomerNotification[]
  ownerNotifications   OwnerNotification[]
  scoreHistory         LeadScoreHistory[]
}

model Call {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  leadId   String
  lead     Lead   @relation(fields: [leadId], references: [id])

  // Exotel / Pipecat (legacy — replaced by Omnidimension)
  exotelCallSid       String? @unique
  omnidimensionCallId String? @unique
  pipecatSession      String? @unique

  // Call metadata
  type       CallType
  direction  String   @default("outbound")
  duration   Int?
  status     CallStatus @default(INITIATED)

  // AI outputs
  transcript    String?
  summary       String?
  recordingUrl  String?

  // Extracted qualification (filled by DeepSeek after call ends)
  extractedData Json?

  // Notification sent
  ownerNotified    Boolean @default(false)
  customerNotified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  lead     Lead?

  // Booking details
  visitDate       DateTime
  visitTime       String
  propertyAddress String
  propertyName    String?
  notes           String?

  // Status
  status        BookingStatus @default(CONFIRMED)
  confirmedAt   DateTime      @default(now())
  reminderSentAt DateTime?
  visitedAt     DateTime?
  noShowAt      DateTime?

  // Source call
  sourceCallId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerNotifications OwnerNotification[]
}

model CustomerNotification {
  id       String @id @default(cuid())
  leadId   String
  lead     Lead   @relation(fields: [leadId], references: [id])

  type     String
  channel  String
  message  String
  status   String   @default("sent")
  waMessageId String?

  sentAt   DateTime @default(now())
}

model LeadScoreHistory {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  score     Int
  factors   Json     @default("{}")
  source    String   @default("auto")  // "auto" | "manual"
  reason    String?

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model OwnerNotification {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  bookingId String?
  booking  Booking? @relation(fields: [bookingId], references: [id])
  leadId    String?
  lead     Lead?   @relation(fields: [leadId], references: [id])

  type     String
  message  String
  status   String   @default("sent")
  waMessageId String?

  sentAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// CAMPAIGN ENUMS
// ─────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignType {
  FOLLOW_UP
  RE_ENGAGEMENT
  NO_SHOW_RECOVERY
  WELCOME
  PROMOTIONAL
  CUSTOM
}

enum TaskAction {
  CALL
  WHATSAPP
  SMS
  EMAIL
  DELAY
  CONDITION
  WEBHOOK
  UPDATE_LEAD_STATUS
  ASSIGN_LEAD
  UPDATE_SCORE
  TAG_LEAD
  CUSTOM
}

// ─────────────────────────────────────────────
// SUBSCRIPTION ENUMS
// ─────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIAL
  PENDING
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
  CANCELLED
}

model Subscription {
  id        String             @id @default(cuid())
  clientId  String
  client    Client             @relation(fields: [clientId], references: [id])

  // Plan
  planName     String
  planTier     String
  billingCycle BillingCycle    @default(MONTHLY)
  status       SubscriptionStatus @default(PENDING)

  // Pricing
  amount       Float
  currency     String           @default("INR")
  totalAmount  Float

  // Period
  startDate    DateTime
  endDate      DateTime
  trialEndDate DateTime?
  cancelledAt  DateTime?

  // Features & Limits
  features Json @default("{}")
  limits   Json @default("{}")

  // Provider (Razorpay)
  provider                String  @default("razorpay")
  providerSubscriptionId  String?

  // Auto-renew
  autoRenew        Boolean @default(true)
  gracePeriodDays  Int     @default(7)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
}

model Invoice {
  id       String       @id @default(cuid())
  clientId String
  client   Client       @relation(fields: [clientId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  // Invoice details
  invoiceNumber String       @unique
  status        InvoiceStatus @default(SENT)
  description   String?

  // Billing
  amount      Float
  totalAmount Float
  currency    String        @default("INR")

  // Period
  periodStart DateTime?
  periodEnd   DateTime?

  // Dates
  issueDate DateTime
  dueDate   DateTime
  paidAt    DateTime?

  // Billing info
  billingName    String?
  billingEmail   String?
  billingPhone   String?
  gstNumber      String?

  // Provider
  providerInvoiceId String?
  invoiceUrl        String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
}

model Payment {
  id       String        @id @default(cuid())
  clientId String
  client   Client        @relation(fields: [clientId], references: [id])
  invoiceId String?
  invoice   Invoice?     @relation(fields: [invoiceId], references: [id])

  // Payment details
  amount        Float
  currency      String        @default("INR")
  status        PaymentStatus @default(PENDING)
  paymentMethod String?

  // Provider
  provider           String  @default("razorpay")
  providerPaymentId  String?
  providerOrderId    String?
  providerSignature  String?

  // Transaction
  transactionId String?  @unique
  receiptUrl    String?

  // Refund
  refundId     String?
  refundAmount Float    @default(0)
  refundReason String?
  refundedAt   DateTime?

  errorLog String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id        String         @id @default(cuid())
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id])

  // Details
  name        String
  description String?
  campaignType CampaignType @default(CUSTOM)
  status      CampaignStatus @default(DRAFT)

  // Targeting
  targetLeadSources  Json     @default("[]")
  targetLeadStatuses Json     @default("[]")
  targetLocations    Json     @default("[]")
  targetTags         Json     @default("[]")
  targetMinScore     Int      @default(0)
  targetMaxScore     Int      @default(100)

  // Schedule
  startDate          DateTime?
  endDate            DateTime?
  timezone           String   @default("Asia/Kolkata")
  workingHoursStart  String   @default("09:00")
  workingHoursEnd    String   @default("18:00")
  workingDays        Json     @default("[1,2,3,4,5,6]")

  // Performance
  leadsProcessed     Int      @default(0)
  leadsTargeted      Int      @default(0)
  callsMade          Int      @default(0)
  messagesSent       Int      @default(0)
  appointmentsBooked Int      @default(0)
  conversions        Int      @default(0)

  // Metadata
  tags               Json     @default("[]")

  // Timestamps
  activatedAt        DateTime?
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tasks CampaignTask[]
}

model CampaignTask {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Task details
  name   String
  action TaskAction
  order  Int

  // Action configuration (varies by action type)
  config Json @default("{}")

  // Delay
  delayAfterPreviousHours   Int @default(0)
  delayAfterPreviousMinutes Int @default(0)

  // Conditional logic
  isCondition       Boolean @default(false)
  conditionField    String?
  conditionOperator String?
  conditionValue    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// INTEGRATION ENUMS
// ─────────────────────────────────────────────

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  DISCONNECTED
}

model Integration {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id])

  // Provider
  provider    String
  name        String
  description String?
  status      IntegrationStatus @default(INACTIVE)

  // Credentials (encrypted at rest by application layer)
  credentials Json @default("{}")
  apiKey      String?
  apiSecret   String?

  // Settings
  settings      Json    @default("{}")
  syncFrequency String  @default("manual")

  // Sync metrics
  lastSyncAt       DateTime?
  nextSyncAt       DateTime?
  totalSynced      Int     @default(0)
  totalErrors      Int     @default(0)
  lastErrorMessage String?
  lastErrorAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookSource {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  name     String
  type     String
  token    String  @unique @default(cuid())
  parserConfig Json
  active   Boolean @default(true)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// AUDIT LOG MODEL
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())

  // Who
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  userId    String?
  adminId   String?

  // What
  action        String
  resourceType  String
  resourceId    String?
  changes       Json     @default("{}")

  // Context
  ipAddress   String?
  userAgent   String?
  status      String   @default("success")  // success | failure
  errorMessage String?

  // Metadata
  metadata    Json     @default("{}")

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
}
