# LeadBridge — Environment Configuration
# Copy to .env and fill in values

# ─── Required (server won't start without these) ────────────────
JWT_SECRET=change-this-to-64-char-random-string
JWT_REFRESH_SECRET=change-this-to-another-64-char-random-string
OMNIDIM_API_KEY=<get from omnidim.io dashboard>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadbridge
DATABASE_URL_PRISMA=postgresql://postgres:postgres@localhost:5432/leadbridge
REDIS_URL=redis://:redispass@localhost:6379

# ─── App ─────────────────────────────────────────────────────────
# NODE_ENV=development|production|test
# PORT=3000
# FRONTEND_URL=http://localhost:3001

# ─── JWT ─────────────────────────────────────────────────────────
# JWT_EXPIRY=15m
# JWT_REFRESH_EXPIRY=30d

# ─── LLM / AI (OpenRouter - free Qwen3 model by default) ────────
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ─── WhatsApp Cloud API ─────────────────────────────────────────
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Razorpay (Subscriptions) ───────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_STARTER=
# RAZORPAY_PLAN_GROWTH=
# RAZORPAY_PLAN_PRO=

# ─── Supabase (Call Recording Storage) ──────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_RECORDINGS_BUCKET=call-recordings

# ─── Email (SMTP via Nodemailer - Resend has been removed) ──────
# Free tiers: AWS SES (62K/mo from EC2), Brevo (300/day), Mailgun (1K/day)
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# FROM_EMAIL=noreply@leadbridge.com
# FROM_NAME=LeadBridge

# ─── Google OAuth ──────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── MessageBird (SMS Fallback for WhatsApp) ────────────────────
# MESSAGEBIRD_API_KEY=
# SMS_SENDER_ID=LeadBrg

# ─── Cron ───────────────────────────────────────────────────────
# CRON_SECRET=change-me-cron-secret

# ─── Encryption (credential storage at rest) ───────────────────
# ENCRYPTION_KEY=
