# LeadBridge — Environment Configuration
# Copy to .env and fill in values

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change-this-to-64-char-random-string
JWT_REFRESH_SECRET=change-this-to-another-64-char-random-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadbridge
DATABASE_URL_PRISMA=postgresql://postgres:postgres@localhost:5432/leadbridge

# Redis
REDIS_URL=redis://localhost:6379

# Omnidimension — AI Voice Agent Platform (primary telephony)
# Get from https://omnidimension.ai dashboard
OMNIDIM_API_KEY=your-omnidimension-api-key
OMNIDIM_BASE_URL=https://backend.omnidim.io/api/v1

# DeepSeek / OpenRouter LLM — used for transcript extraction, chatbot, and script generation
# Default: Qwen3 Next 80B A3B via OpenRouter (free)
DEEPSEEK_API_KEY=sk-your-openrouter-api-key
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_PLAN_STARTER=plan_xxxxxxxxxx
RAZORPAY_PLAN_GROWTH=plan_xxxxxxxxxx
RAZORPAY_PLAN_PRO=plan_xxxxxxxxxx

# Supabase (File Storage for call recordings & documents)
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_RECORDINGS_BUCKET=call-recordings

# ─── Email Configuration (SMTP — works with any provider) ─────
# Primary: SMTP (nodemailer) — works with AWS SES, SendGrid, Gmail, Mailgun, etc.
# AWS SES is cheapest: ~$0.10/1000 emails ($5 for 50K emails/month)
#
# To use AWS SES:
#   1. Verify domain in AWS SES Console
#   2. Create SMTP credentials (IAM user with ses:SendRawEmail)
#   3. Set the following:
#
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
FROM_EMAIL=noreply@leadbridge.com
FROM_NAME=LeadBridge
#
# Alternative: SendGrid SMTP — host=smtp.sendgrid.net, port=587, user=apikey, pass=<api key>
# Alternative: Gmail SMTP — host=smtp.gmail.com, port=587, user=<email>, pass=<app password>
#
# Fallback: Resend HTTP API (used only if SMTP above is not configured)
# Free: 100 emails/day, Paid: $10/month for 50K emails
# Sign up at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxx

# MessageBird (SMS fallback — used when WhatsApp delivery fails)
# Sign up at https://messagebird.com
MESSAGEBIRD_API_KEY=your-messagebird-api-key
SMS_SENDER_ID=LeadBrg

# Encryption (for credential storage at rest)
# Optional in dev — defaults to JWT_SECRET-based derivation if not set
ENCRYPTION_KEY=your-32-char-encryption-key

# Cron
CRON_SECRET=change-me-cron-secret

# Google OAuth (optional — for Google Sign-In)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
