{
  "name": "leadbridge-server",
  "version": "1.0.0",
  "description": "LeadBridge - AI Real Estate Calling Agency Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:call": "tsx src/workers/call.worker.ts",
    "worker:extraction": "tsx src/workers/extraction.worker.ts",
    "worker:notification": "tsx src/workers/notification.worker.ts",
    "worker:followup": "tsx src/workers/followup.worker.ts",
    "worker:reminder": "tsx src/workers/reminder.worker.ts",
"worker:webhook-retry": "tsx src/workers/webhook-retry.worker.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.19.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.7.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^140.0.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "node-cron": "^4.2.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "razorpay": "^2.9.6",
    "resend": "^6.12.4",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prisma": "^5.19.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
