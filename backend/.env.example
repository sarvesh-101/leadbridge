# LeadFlow AI OS - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=LeadFlow AI OS
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leadflow_ai
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/leadflow_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (CHANGE THESE IN PRODUCTION)
SECRET_KEY=generate-a-64-char-random-secret-key-here
JWT_REFRESH_SECRET=generate-another-64-char-random-secret-key-here
ENCRYPTION_KEY=generate-a-32-char-encryption-key-here

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=leadflow-ai-storage

# AI - DeepSeek LLM
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# AI - Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=your-deepgram-api-key

# AI - Cartesia (Text-to-Speech)
CARTESIA_API_KEY=your-cartesia-api-key

# Telephony - Exotel
EXOTEL_SID=your-exotel-sid
EXOTEL_TOKEN=your-exotel-token
EXOTEL_SUBDOMAIN=your-exotel-subdomain

# WhatsApp Cloud API
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id

# Email - Resend
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@leadflow.ai
RESEND_FROM_NAME=LeadFlow AI OS

# Celery (Task Queue)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
